      <dcterms:description xml:lang="da">overordnet gruppering af kortværker, hvor metadatafelter er identisk </dcterms:description>
      <dcterms:provenance xml:lang="da">første version af kodelisten </dcterms:provenance>
      <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/deed.da"/>
